<?xml version="1.0"?>
<robot name="simple_quad_visual">

  <link name="base_link">

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.35"/>
      <inertia
        ixx="0.02"
        iyy="0.02"
        izz="0.04"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <!-- Main collision body -->
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.12 0.12 0.04"/>
      </geometry>
    </collision>

    <!-- Central body -->
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.12 0.12 0.04"/>
      </geometry>
      <material name="body_black">
        <color rgba="0.12 0.12 0.12 1"/>
      </material>
    </visual>

    <!-- X arms -->
    <visual>
      <origin xyz="0.085 0.085 0"/>
      <geometry>
        <box size="0.14 0.018 0.012"/>
      </geometry>
      <material name="arm_red">
        <color rgba="0.75 0.15 0.15 1"/>
      </material>
    </visual>

    <visual>
      <origin xyz="0.085 -0.085 0"/>
      <geometry>
        <box size="0.14 0.018 0.012"/>
      </geometry>
      <material name="arm_black">
        <color rgba="0.18 0.18 0.18 1"/>
      </material>
    </visual>

    <visual>
      <origin xyz="-0.085 0.085 0"/>
      <geometry>
        <box size="0.14 0.018 0.012"/>
      </geometry>
      <material name="arm_black2">
        <color rgba="0.18 0.18 0.18 1"/>
      </material>
    </visual>

    <visual>
      <origin xyz="-0.085 -0.085 0"/>
      <geometry>
        <box size="0.14 0.018 0.012"/>
      </geometry>
      <material name="arm_red2">
        <color rgba="0.75 0.15 0.15 1"/>
      </material>
    </visual>

    <!-- Motor pods -->
    <visual>
      <origin xyz="0.17 0.17 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.018"/>
      </geometry>
      <material name="motor_dark">
        <color rgba="0.08 0.08 0.08 1"/>
      </material>
    </visual>

    <visual>
      <origin xyz="0.17 -0.17 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.018"/>
      </geometry>
      <material name="motor_dark2">
        <color rgba="0.08 0.08 0.08 1"/>
      </material>
    </visual>

    <visual>
      <origin xyz="-0.17 0.17 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.018"/>
      </geometry>
      <material name="motor_dark3">
        <color rgba="0.08 0.08 0.08 1"/>
      </material>
    </visual>

    <visual>
      <origin xyz="-0.17 -0.17 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.018"/>
      </geometry>
      <material name="motor_dark4">
        <color rgba="0.08 0.08 0.08 1"/>
      </material>
    </visual>

    <!-- Prop discs -->
    <visual>
      <origin xyz="0.17 0.17 0.012"/>
      <geometry>
        <cylinder radius="0.07" length="0.003"/>
      </geometry>
      <material name="prop_tint1">
        <color rgba="0.85 0.85 0.95 0.45"/>
      </material>
    </visual>

    <visual>
      <origin xyz="0.17 -0.17 0.012"/>
      <geometry>
        <cylinder radius="0.07" length="0.003"/>
      </geometry>
      <material name="prop_tint2">
        <color rgba="0.85 0.85 0.95 0.45"/>
      </material>
    </visual>

    <visual>
      <origin xyz="-0.17 0.17 0.012"/>
      <geometry>
        <cylinder radius="0.07" length="0.003"/>
      </geometry>
      <material name="prop_tint3">
        <color rgba="0.85 0.85 0.95 0.45"/>
      </material>
    </visual>

    <visual>
      <origin xyz="-0.17 -0.17 0.012"/>
      <geometry>
        <cylinder radius="0.07" length="0.003"/>
      </geometry>
      <material name="prop_tint4">
        <color rgba="0.85 0.85 0.95 0.45"/>
      </material>
    </visual>

    <!-- Front direction marker -->
    <visual>
      <origin xyz="0.085 0 0.03"/>
      <geometry>
        <box size="0.045 0.022 0.012"/>
      </geometry>
      <material name="front_marker">
        <color rgba="1.0 0.45 0.1 1"/>
      </material>
    </visual>

    <!-- Camera nub -->
    <visual>
      <origin xyz="0.075 0 0.012"/>
      <geometry>
        <sphere radius="0.012"/>
      </geometry>
      <material name="camera_blue">
        <color rgba="0.2 0.45 0.9 1"/>
      </material>
    </visual>

  </link>

</robot>